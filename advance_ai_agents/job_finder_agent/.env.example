OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Search provider: "websearch" (default, cheap, requires Docker) or "firecrawl" (higher quality, requires API key)
SEARCH_PROVIDER=websearch

# WebSearch-MCP — used when SEARCH_PROVIDER=websearch
# Crawl4AI handles scraping (YC Jobs, Indeed) — no API key needed, runs locally
# Start the crawler Docker service first: docker-compose up -d
WEBSEARCH_API_URL=http://localhost:3001

# Firecrawl MCP — used when SEARCH_PROVIDER=firecrawl
# Get your key at https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key